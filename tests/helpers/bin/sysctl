#!/bin/bash
# Mock sysctl for testing -- returns RAM in bytes
# Override: MOCK_RAM_BYTES (default: 34359738368 = 32GB)
_bytes="${MOCK_RAM_BYTES:-34359738368}"
case "$1" in
  hw.memsize)   echo "hw.memsize: ${_bytes}" ;;
  -n)
    case "$2" in
      hw.memsize) echo "${_bytes}" ;;
      *)          echo "0" ;;
    esac
    ;;
  *)            echo "mock: sysctl $*" ;;
esac
exit 0

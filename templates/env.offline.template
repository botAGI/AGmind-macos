# AGMind .env -- Offline Profile (Generated by install.sh)
# Do not edit manually -- re-run install.sh to regenerate.

# =============================================================================
# Compose Profiles
# =============================================================================
COMPOSE_PROFILES={{COMPOSE_PROFILES}}

# =============================================================================
# Dify Core
# =============================================================================
SECRET_KEY={{DIFY_SECRET_KEY}}
DEPLOY_ENV=PRODUCTION
LOG_LEVEL=INFO
MIGRATION_ENABLED=true

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_TYPE=postgresql
DB_USERNAME=postgres
DB_PASSWORD={{DB_PASSWORD}}
DB_HOST=db_postgres
DB_PORT=5432
DB_DATABASE=dify

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD={{REDIS_PASSWORD}}
CELERY_BROKER_URL=redis://:{{REDIS_PASSWORD}}@redis:6379/1

# =============================================================================
# Storage
# =============================================================================
STORAGE_TYPE=opendal
OPENDAL_SCHEME=fs
OPENDAL_FS_ROOT=storage

# =============================================================================
# Ollama (hardcoded -- containers reach host Ollama via Docker bridge)
# =============================================================================
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# =============================================================================
# Vector Store
# =============================================================================
VECTOR_STORE={{WIZARD_VECTOR_DB}}
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY={{WEAVIATE_API_KEY}}
WEAVIATE_AUTHENTICATION_APIKEY_ALLOWED_KEYS={{WEAVIATE_API_KEY}}
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY={{QDRANT_API_KEY}}

# =============================================================================
# Models
# =============================================================================
LLM_MODEL={{WIZARD_LLM_MODEL}}
EMBED_MODEL={{WIZARD_EMBED_MODEL}}

# =============================================================================
# ETL
# =============================================================================
ETL_TYPE={{ETL_TYPE}}
UNSTRUCTURED_API_URL=http://unstructured:8000

# =============================================================================
# Code Execution Sandbox
# =============================================================================
CODE_EXECUTION_ENDPOINT=http://sandbox:8194
CODE_EXECUTION_API_KEY={{SANDBOX_API_KEY}}
SANDBOX_API_KEY={{SANDBOX_API_KEY}}

# =============================================================================
# SSRF Proxy
# =============================================================================
SSRF_PROXY_HTTP_URL=http://ssrf_proxy:3128
SSRF_PROXY_HTTPS_URL=http://ssrf_proxy:3128

# =============================================================================
# Plugin Daemon
# =============================================================================
PLUGIN_DAEMON_KEY={{PLUGIN_DAEMON_KEY}}
PLUGIN_DIFY_INNER_API_KEY={{DIFY_INNER_API_KEY}}
PLUGIN_DIFY_INNER_API_URL=http://api:5001

# =============================================================================
# Nginx
# =============================================================================
NGINX_PORT=80
NGINX_HTTPS_ENABLED=false

# =============================================================================
# Open WebUI
# =============================================================================
WEBUI_SECRET_KEY={{OPENWEBUI_SECRET}}
